{
  "name": "catective Blog",
  "version": "1.0.0",
  "scripts": {
    "build": "bun run tailwind:build && hugo --minify",
    "build:dev": "bun run tailwind:build && hugo --minify && hugo server -D",
    "tailwind:build": "bunx @tailwindcss/cli -i ./themes/catective/assets/css/main.css -o ./themes/catective/assets/css/style.css --minify"
  },
  "devDependencies": {
    "tailwindcss": "^4.1.8",
    "@tailwindcss/cli": "^4.1.8"
  }
}